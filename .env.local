# MAILER_SENDMAIL_PATH=

## Database setup.
# DB_CONNECTION=sqlite
# DB_DSN="sqlite:${APP_BASE_PATH}/database/codefy.sqlite"
# DB_TABLE_PREFIX=
# DB_PERSISTENT=false
# DB_USER=
# DB_PASSWORD=

